# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aeronetb
PG_USER=postgres
PG_PASSWORD=your_pg_password

# ── MongoDB ─────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=aeronetb_db

# ── Auth ────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
